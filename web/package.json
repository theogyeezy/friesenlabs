{
  "name": "uplift-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:real": "VITE_API_MOCK=0 vite build --outDir dist-real",
    "build:auth": "VITE_API_MOCK=0 VITE_COGNITO_DOMAIN=auth-e2e.uplift.invalid VITE_COGNITO_CLIENT_ID=e2e-client-id VITE_COGNITO_REGION=us-east-1 vite build --outDir dist-auth",
    "preview": "vite preview",
    "preview:real": "vite preview --outDir dist-real --port 4174",
    "preview:auth": "vite preview --outDir dist-auth --port 4175",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run && node --test test/*.test.mjs",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test e2e/a11y.spec.ts --project=chromium",
    "test:visual": "RUN_VISUAL=1 playwright test --project=visual",
    "test:visual:update": "RUN_VISUAL=1 playwright test --project=visual --update-snapshots",
    "test:smoke": "playwright test -c playwright.smoke.config.ts"
  },
  "dependencies": {
    "dompurify": "^3.4.8",
    "posthog-js": "^1.386.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.19.42",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.19.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
