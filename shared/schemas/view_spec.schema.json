{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uplift/view_spec.schema.json",
  "title": "Uplift dashboard view-spec",
  "description": "A declarative dashboard spec. SPEC, NOT CODE: no React/JS, only catalog components bound to Cube metrics. Validated before anything renders. Versioned additively: spec_version 1 is the original kpi/chart/table catalog; spec_version 2 adds funnel, leaderboard, stat-with-sparkline, cohort-grid, markdown-note, the grid/span layout primitive, and the kind=dashboard composition spec. v1 specs (no spec_version, or spec_version 1) remain valid unchanged.",
  "oneOf": [
    { "$ref": "#/$defs/viewSpec" },
    { "$ref": "#/$defs/dashboardSpec" }
  ],
  "$defs": {
    "viewSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["view_id", "title", "layout", "semantic_refs"],
      "properties": {
        "kind": { "const": "view" },
        "view_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1, "maxLength": 200 },
        "version": { "type": "integer", "minimum": 1 },
        "spec_version": { "type": "integer", "enum": [1, 2] },
        "source_prompt": { "type": "string" },
        "grid": { "$ref": "#/$defs/grid" },
        "semantic_refs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]*\\.[A-Za-z][A-Za-z0-9_]*$" },
          "minItems": 1
        },
        "layout": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/kpi" },
              { "$ref": "#/$defs/chart" },
              { "$ref": "#/$defs/table" },
              { "$ref": "#/$defs/funnel" },
              { "$ref": "#/$defs/leaderboard" },
              { "$ref": "#/$defs/statWithSparkline" },
              { "$ref": "#/$defs/cohortGrid" },
              { "$ref": "#/$defs/markdownNote" }
            ]
          }
        }
      }
    },
    "dashboardSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "view_id", "title", "spec_version", "items"],
      "properties": {
        "kind": { "const": "dashboard" },
        "view_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1, "maxLength": 200 },
        "version": { "type": "integer", "minimum": 1 },
        "spec_version": { "const": 2 },
        "source_prompt": { "type": "string" },
        "grid": { "$ref": "#/$defs/grid" },
        "items": {
          "type": "array",
          "minItems": 1,
          "maxItems": 24,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["view_id"],
            "properties": {
              "view_id": { "type": "string", "minLength": 1, "maxLength": 128 },
              "span": { "$ref": "#/$defs/span" }
            }
          }
        }
      }
    },
    "grid": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "columns": { "type": "integer", "minimum": 1, "maximum": 12 }
      }
    },
    "span": { "type": "integer", "minimum": 1, "maximum": 12 },
    "cubeQuery": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "measures": { "type": "array", "items": { "$ref": "#/$defs/member" } },
        "dimensions": { "type": "array", "items": { "$ref": "#/$defs/member" } },
        "timeDimensions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "dimension": { "$ref": "#/$defs/member" },
              "granularity": { "type": "string", "enum": ["day", "week", "month", "quarter", "year"] },
              "dateRange": { "type": "array", "items": { "type": "string" }, "minItems": 2, "maxItems": 2 }
            },
            "required": ["dimension"]
          }
        },
        "filters": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "member": { "$ref": "#/$defs/member" },
              "operator": { "type": "string", "enum": ["equals", "notEquals", "gt", "gte", "lt", "lte", "set", "notSet", "contains"] },
              "values": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["member", "operator"]
          }
        }
      }
    },
    "member": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]*\\.[A-Za-z][A-Za-z0-9_]*$" },
    "kpi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "metric"],
      "properties": {
        "type": { "const": "kpi" },
        "title": { "type": "string" },
        "metric": { "$ref": "#/$defs/member" },
        "filter": { "$ref": "#/$defs/cubeQuery" },
        "span": { "$ref": "#/$defs/span" }
      }
    },
    "chart": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "encoding", "query"],
      "properties": {
        "type": { "const": "chart" },
        "title": { "type": "string" },
        "encoding": { "const": "vega-lite" },
        "spec": { "$ref": "#/$defs/chartSpecFragment" },
        "query": { "$ref": "#/$defs/cubeQuery" },
        "span": { "$ref": "#/$defs/span" }
      }
    },
    "chartSpecFragment": {
      "description": "Whitelisted Vega-Lite fragment: mark + encoding + transform ONLY. Everything else (params, signals, data, datasets, usermeta, projection, config, width, ...) is rejected — the renderer owns data/size, and a fragment must stay declarative data, never code or a loader. No key named href/url may appear anywhere inside (kills link channels and URL-referencing lookup transforms).",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mark": { "type": "string", "minLength": 1 },
        "encoding": {
          "type": "object",
          "$ref": "#/$defs/noLinkValue"
        },
        "transform": {
          "type": "array",
          "items": { "type": "object", "$ref": "#/$defs/noLinkValue" }
        }
      }
    },
    "noLinkValue": {
      "description": "Recursively forbids any object key named href or url (no links, no external loads).",
      "anyOf": [
        { "not": { "type": ["object", "array"] } },
        { "type": "array", "items": { "$ref": "#/$defs/noLinkValue" } },
        {
          "type": "object",
          "propertyNames": { "not": { "enum": ["href", "url"] } },
          "additionalProperties": { "$ref": "#/$defs/noLinkValue" }
        }
      ]
    },
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "query"],
      "properties": {
        "type": { "const": "table" },
        "title": { "type": "string" },
        "query": { "$ref": "#/$defs/cubeQuery" },
        "span": { "$ref": "#/$defs/span" }
      }
    },
    "funnel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "query"],
      "properties": {
        "type": { "const": "funnel" },
        "title": { "type": "string" },
        "query": { "$ref": "#/$defs/cubeQuery" },
        "span": { "$ref": "#/$defs/span" }
      }
    },
    "leaderboard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "query"],
      "properties": {
        "type": { "const": "leaderboard" },
        "title": { "type": "string" },
        "query": { "$ref": "#/$defs/cubeQuery" },
        "limit": { "type": "integer", "minimum": 1, "maximum": 100 },
        "span": { "$ref": "#/$defs/span" }
      }
    },
    "statWithSparkline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "metric", "trend"],
      "properties": {
        "type": { "const": "stat-with-sparkline" },
        "title": { "type": "string" },
        "metric": { "$ref": "#/$defs/member" },
        "filter": { "$ref": "#/$defs/cubeQuery" },
        "trend": { "$ref": "#/$defs/cubeQuery" },
        "span": { "$ref": "#/$defs/span" }
      }
    },
    "cohortGrid": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "query"],
      "properties": {
        "type": { "const": "cohort-grid" },
        "title": { "type": "string" },
        "query": { "$ref": "#/$defs/cubeQuery" },
        "span": { "$ref": "#/$defs/span" }
      }
    },
    "markdownNote": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "body"],
      "properties": {
        "type": { "const": "markdown-note" },
        "title": { "type": "string" },
        "body": { "type": "string", "minLength": 1, "maxLength": 4000 },
        "span": { "$ref": "#/$defs/span" }
      }
    }
  }
}
