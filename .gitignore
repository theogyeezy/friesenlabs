# --- Secrets & local env (NEVER commit) ---
.env
.env.*
*.pem
*.key
# a top-level secrets/ dir only — NOT infra/modules/secrets/ (a source module)
/secrets/
**/secrets.auto.tfvars
# non-secret per-env config (infra/envs/*.tfvars) is tracked; all other tfvars are ignored
*.tfvars
!example.tfvars
!infra/envs/*.tfvars

# --- Python ---
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Node / web ---
node_modules/
web/dist/
web/.next/
web/out/
web/node_modules/
*.tsbuildinfo
playwright-report/
test-results/
.playwright/

# --- Terraform ---
.terraform/
*.tfstate
*.tfstate.*
crash.log
.terraform.lock.hcl

# --- Worker logs / scratch ---
logs/*.log
.DS_Store

# --- Confidential spec docs (kept local only — never publish) ---
docs/*.pdf
docs/uplift-build-guide.txt
docs/uplift-infra-design.txt

# terraform backend config (contains account-id bucket name) - keep out of the public repo
infra/backend.hcl
infra/prod.auto.tfvars

# Claude Code per-machine settings (permissions allowlists are machine-specific)
.claude/settings.local.json
